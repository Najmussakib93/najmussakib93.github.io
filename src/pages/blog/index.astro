---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Blog — Najmus Sakib"
  description="Thoughts on software engineering, machine learning, and computer science."
>
  <Header />
  <main class="min-h-screen pt-24 pb-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto">
      <div class="mb-12">
        <h1 class="text-4xl font-extrabold text-gray-900 dark:text-white mb-3">Blog</h1>
        <p class="text-gray-500 dark:text-gray-400 text-lg">
          Thoughts on software, systems, and the craft of building things.
        </p>
      </div>

      {posts.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-5xl mb-4">✍️</p>
          <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">Coming soon</h2>
          <p class="text-gray-500 dark:text-gray-400">I'm working on my first posts. Check back soon!</p>
          <a href="/" class="mt-6 inline-block text-indigo-600 dark:text-indigo-400 hover:underline font-medium">
            ← Back to portfolio
          </a>
        </div>
      ) : (
        <div class="space-y-8">
          {posts.map((post) => (
            <article class="group">
              <a href={`/blog/${post.slug}`} class="block">
                <div class="bg-white dark:bg-gray-900 rounded-2xl p-6 border border-gray-200 dark:border-gray-800 hover:border-indigo-300 dark:hover:border-indigo-700 hover:shadow-md transition-all">
                  <div class="flex flex-wrap items-center gap-3 mb-3">
                    <time class="text-sm text-gray-500 dark:text-gray-400">
                      {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </time>
                    {post.data.tags.map((tag: string) => (
                      <span class="px-2 py-0.5 rounded-md text-xs font-medium bg-indigo-50 dark:bg-indigo-950 text-indigo-700 dark:text-indigo-300">
                        {tag}
                      </span>
                    ))}
                  </div>
                  <h2 class="text-xl font-bold text-gray-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors mb-2">
                    {post.data.title}
                  </h2>
                  <p class="text-gray-600 dark:text-gray-400 leading-relaxed">{post.data.description}</p>
                  <p class="mt-4 text-sm font-semibold text-indigo-600 dark:text-indigo-400 group-hover:underline">
                    Read more →
                  </p>
                </div>
              </a>
            </article>
          ))}
        </div>
      )}
    </div>
  </main>
  <Footer />
</BaseLayout>
