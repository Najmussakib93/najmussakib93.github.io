---
import SectionHeading from './SectionHeading.astro';
import { experience } from '../data/experience';

const typeBadgeColors: Record<string, string> = {
  'Full-time': 'bg-green-100 dark:bg-green-950 text-green-700 dark:text-green-300 border-green-200 dark:border-green-800',
  'Part-time': 'bg-yellow-100 dark:bg-yellow-950 text-yellow-700 dark:text-yellow-300 border-yellow-200 dark:border-yellow-800',
  'Internship': 'bg-blue-100 dark:bg-blue-950 text-blue-700 dark:text-blue-300 border-blue-200 dark:border-blue-800',
  'Freelance': 'bg-purple-100 dark:bg-purple-950 text-purple-700 dark:text-purple-300 border-purple-200 dark:border-purple-800',
  'Research': 'bg-orange-100 dark:bg-orange-950 text-orange-700 dark:text-orange-300 border-orange-200 dark:border-orange-800',
};
---

<section id="experience" class="section-padding bg-gray-50 dark:bg-gray-900">
  <div class="container-max">
    <div class="fade-in-up">
      <SectionHeading title="Experience" subtitle="Where I've worked and what I've built." />
    </div>

    <div class="relative max-w-3xl mx-auto">
      <!-- Vertical line -->
      <div class="absolute left-6 top-0 bottom-0 w-0.5 bg-gradient-to-b from-indigo-500 to-purple-500 hidden sm:block"></div>

      <div class="space-y-10">
        {experience.map((entry) => (
          <div class="fade-in-up relative flex gap-6">
            <!-- Dot -->
            <div class="hidden sm:flex flex-shrink-0 items-start pt-1.5">
              <div class="w-12 h-12 rounded-full bg-indigo-100 dark:bg-indigo-950 border-2 border-indigo-500 flex items-center justify-center z-10">
                <svg class="h-5 w-5 text-indigo-600 dark:text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
            </div>

            <!-- Card -->
            <div class="flex-1 bg-white dark:bg-gray-950 rounded-2xl p-6 border border-gray-200 dark:border-gray-800 hover:border-indigo-300 dark:hover:border-indigo-700 transition-all hover:shadow-md">
              <div class="flex flex-wrap items-start justify-between gap-3 mb-3">
                <div>
                  <h3 class="text-lg font-bold text-gray-900 dark:text-white">{entry.title}</h3>
                  <p class="text-indigo-600 dark:text-indigo-400 font-semibold text-sm mt-0.5">{entry.company}</p>
                </div>
                <div class="flex flex-col items-end gap-1.5">
                  <span class={`inline-block px-2.5 py-0.5 rounded-full text-xs font-semibold border ${typeBadgeColors[entry.type] || ''}`}>
                    {entry.type}
                  </span>
                  <span class="text-xs text-gray-500 dark:text-gray-400">{entry.period}</span>
                  <span class="text-xs text-gray-400 dark:text-gray-500">{entry.location}</span>
                </div>
              </div>

              <p class="text-sm text-gray-600 dark:text-gray-400 mb-3">{entry.description}</p>

              <ul class="space-y-1.5 mb-4">
                {entry.highlights.map((h) => (
                  <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-400">
                    <span class="text-indigo-500 mt-0.5 flex-shrink-0">▸</span>
                    {h}
                  </li>
                ))}
              </ul>

              {entry.tech && entry.tech.length > 0 && (
                <div class="flex flex-wrap gap-2">
                  {entry.tech.map((t) => (
                    <span class="px-2.5 py-0.5 rounded-md text-xs font-medium bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400">
                      {t}
                    </span>
                  ))}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
