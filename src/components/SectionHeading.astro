---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="text-center mb-12">
  <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-3">
    {title}
  </h2>
  {subtitle && (
    <p class="text-gray-500 dark:text-gray-400 max-w-2xl mx-auto text-lg">
      {subtitle}
    </p>
  )}
  <div class="mt-4 flex justify-center">
    <div class="h-1 w-16 rounded-full bg-indigo-500"></div>
  </div>
</div>
