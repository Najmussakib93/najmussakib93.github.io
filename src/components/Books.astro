---
import SectionHeading from './SectionHeading.astro';
import { books } from '../data/books';

const categoryColors: Record<string, string> = {
  'Software Engineering': 'bg-blue-50 dark:bg-blue-950 text-blue-700 dark:text-blue-300 border-blue-200 dark:border-blue-800',
  'Systems': 'bg-purple-50 dark:bg-purple-950 text-purple-700 dark:text-purple-300 border-purple-200 dark:border-purple-800',
  'Machine Learning': 'bg-orange-50 dark:bg-orange-950 text-orange-700 dark:text-orange-300 border-orange-200 dark:border-orange-800',
  'Algorithms': 'bg-green-50 dark:bg-green-950 text-green-700 dark:text-green-300 border-green-200 dark:border-green-800',
};

function getStars(rating?: number): string {
  if (!rating) return '';
  return '★'.repeat(rating) + '☆'.repeat(5 - rating);
}
---

<section id="books" class="section-padding bg-white dark:bg-gray-950">
  <div class="container-max">
    <div class="fade-in-up">
      <SectionHeading
        title="Books I've Read"
        subtitle="A curated reading list that shaped how I think about software."
      />
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {books.map((book) => (
        <div class="fade-in-up group bg-gray-50 dark:bg-gray-900 rounded-2xl p-5 border border-gray-200 dark:border-gray-800 hover:border-indigo-300 dark:hover:border-indigo-700 transition-all hover:shadow-md hover:-translate-y-0.5">
          <!-- Book icon + category -->
          <div class="flex items-start justify-between gap-2 mb-3">
            <div class="text-2xl select-none">📖</div>
            <span class={`inline-block px-2.5 py-0.5 rounded-full text-xs font-semibold border ${categoryColors[book.category] || 'bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 border-gray-200 dark:border-gray-700'}`}>
              {book.category}
            </span>
          </div>

          <h3 class="font-bold text-gray-900 dark:text-white text-base leading-snug mb-1 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
            {book.title}
          </h3>
          <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">{book.author}</p>

          {book.rating && (
            <p class="text-yellow-400 text-sm mb-3 tracking-wider" aria-label={`${book.rating} out of 5 stars`}>
              {getStars(book.rating)}
            </p>
          )}

          {book.notes && (
            <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed italic">
              "{book.notes}"
            </p>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
