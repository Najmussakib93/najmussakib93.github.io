---
import SectionHeading from './SectionHeading.astro';
import { techStacks } from '../data/techStacks';
---

<section id="tech" class="section-padding bg-gray-50 dark:bg-gray-900">
  <div class="container-max">
    <div class="fade-in-up">
      <SectionHeading
        title="Tech Stack"
        subtitle="Technologies I work with and love."
      />
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {techStacks.map((category) => (
        <div class="fade-in-up bg-white dark:bg-gray-950 rounded-2xl p-6 border border-gray-200 dark:border-gray-800 hover:border-indigo-300 dark:hover:border-indigo-700 transition-all hover:shadow-md">
          <div class="flex items-center gap-3 mb-5">
            <span class="text-2xl">{category.emoji}</span>
            <h3 class="text-base font-bold text-gray-900 dark:text-white">{category.category}</h3>
          </div>
          <div class="flex flex-wrap gap-2">
            {category.items.map((item) => (
              <span class="px-3 py-1.5 rounded-lg text-sm font-medium bg-gray-50 dark:bg-gray-900 text-gray-700 dark:text-gray-300 border border-gray-200 dark:border-gray-700 hover:border-indigo-300 dark:hover:border-indigo-700 hover:text-indigo-700 dark:hover:text-indigo-300 transition-colors cursor-default">
                {item.name}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
